# URL backend nawasenadara-backend (lihat repo backend, PORT default 8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WAJIB sama persis dengan GOOGLE_CLIENT_ID di .env backend, supaya
# audience ID token yang diverifikasi backend (google-auth-library)
# cocok dengan client ID yang dipakai frontend untuk memunculkan
# tombol Google Sign-In.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
